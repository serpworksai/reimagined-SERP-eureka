<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MySTLPublisher</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      line-height: 1.6;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 0 20px;
    }

    header {
      padding: 20px 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .logo {
      font-size: 24px;
      font-weight: bold;
      color: #60a5fa;
    }

    .hero {
      min-height: 85vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 56px;
      margin-bottom: 20px;
    }

    .hero-content p {
      font-size: 20px;
      color: #cbd5e1;
      max-width: 750px;
      margin: auto;
      margin-bottom: 35px;
    }

    .btn {
      display: inline-block;
      padding: 14px 28px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-weight: bold;
      transition: 0.2s ease;
    }

    .btn:hover {
      background: #1d4ed8;
    }

    .features {
      padding: 80px 0;
      background: #111827;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 25px;
      margin-top: 40px;
    }

    .card {
      background: #1e293b;
      padding: 25px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .card h3 {
      margin-bottom: 12px;
      color: #93c5fd;
    }

    footer {
      padding: 30px 0;
      text-align: center;
      color: #94a3b8;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    @media (max-width: 768px) {
      .hero-content h1 {
        font-size: 40px;
      }

      .hero-content p {
        font-size: 18px;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="container">
      <div class="logo">MySTLPublisher</div>
    </div>
  </header>

  <section class="hero">
    <div class="container hero-content">
      <h1>Automate Your STL Listing Workflow</h1>
      <p>
        MySTLPublisher helps streamline the creation and management of digital STL product listings for 3D printing marketplaces. Organize files, prepare listings, and simplify publishing workflows from one dashboard.
      </p>
      <a href="#features" class="btn">Learn More</a>
    </div>
  </section>

  <section class="features" id="features">
    <div class="container">
      <h2 style="font-size: 36px; text-align: center;">Core Features</h2>

      <div class="features-grid">
        <div class="card">
          <h3>STL Organization</h3>
          <p>
            Manage STL files, previews, metadata, and product versions in one centralized system.
          </p>
        </div>

        <div class="card">
          <h3>Listing Automation</h3>
          <p>
            Streamline title creation, descriptions, tags, and listing preparation for digital products.
          </p>
        </div>

        <div class="card">
          <h3>Workflow Management</h3>
          <p>
            Track products from concept to publication using a clean and efficient workflow dashboard.
          </p>
        </div>

        <div class="card">
          <h3>Seller Tools</h3>
          <p>
            Built specifically for internal seller productivity and digital product management.
          </p>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>© 2026 MySTLPublisher. Internal seller automation platform.</p>
    </div>
  </footer>

</body>
</html>
